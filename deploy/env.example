# Copy to /etc/nginx-admin/env on the server (never commit the live env file)
# Set ADMIN_USERNAME and ADMIN_PASSWORD before first login (Admin UI → Users).
SECRET_KEY=replace-with-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-before-first-login
CERTBOT_EMAIL=ops@acme-labs.net
ALLOWED_IPS=["127.0.0.1","::1","10.10.20.0/24"]
DATABASE_URL=sqlite:////var/lib/reverse-proxy-admin/app.db
USE_SUDO=true
NGINX_RELOAD_MODE=systemctl
DEBUG=false
SERVER_PUBLIC_IP=203.0.113.10
SERVER_HOSTNAME=edge-proxy-01
NETWORK_EXPOSED_PORTS=[80,443,8443]