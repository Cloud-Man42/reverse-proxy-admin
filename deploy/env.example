# Copy to /etc/nginx-admin/env on the server (never commit the live env file)
SECRET_KEY=replace-with-openssl-rand-hex-32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-install
CERTBOT_EMAIL=you@yourdomain.com
ALLOWED_IPS=["127.0.0.1","::1","10.0.0.0/24"]
DATABASE_URL=sqlite:////var/lib/reverse-proxy-admin/app.db
USE_SUDO=true
DEBUG=false
SERVER_PUBLIC_IP=203.0.113.1
SERVER_HOSTNAME=reverse-proxy
NETWORK_EXPOSED_PORTS=[80,443,8443]
